# PostgreSQL production store. Omit to use the single-process JSON development fallback.
DATABASE_URL=postgresql://postgres:<password>@localhost:5432/smarthub

# Optional local model mirror.
# SMARTHUB_MODEL_HUB=https://your-hugging-face-compatible-mirror.example

# Optional roots for local runtime data.
# SMARTHUB_DATA_FILE=./data/smarthub.json
# SMARTHUB_MODEL_ROOT=./data/models
# SMARTHUB_DOCUMENT_ROOT=./data/knowledge-bases
